{
  "name": "easy-pie-chart",
  "description": "Lightweight plugin to render simple, animated and retina optimized pie charts",
  "keywords": [
    "pie chart",
    "chart",
    "circular progress",
    "percent",
    "progress bar"
  ],
  "license": "MIT",
  "version": "3.0.0",
  "author": {
    "name": "Robert Fleischmann",
    "email": "rendro87@gmail.com",
    "url": "https://robert-fleischmann.com"
  },
  "contributors": [
    {
      "name": "Moritz",
      "url": "https://github.com/mrzmyr"
    }
  ],
  "main": "./dist/easypiechart.js",
  "module": "./dist/easypiechart.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/easypiechart.mjs",
      "require": "./dist/easypiechart.js"
    },
    "./jquery": {
      "types": "./dist/jquery.d.ts",
      "import": "./dist/jquery.easypiechart.mjs",
      "require": "./dist/jquery.easypiechart.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rendro/easy-pie-chart.git"
  },
  "scripts": {
    "build": "vite build && vite build --mode umd && vite build --mode umd-min && vite build --mode jquery && vite build --mode jquery-umd && vite build --mode jquery-umd-min && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
