{
  // Typecheck-only config: covers the tests as well as the sources, without
  // emitting declarations for them into dist/.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "emitDeclarationOnly": false,
    "types": ["vitest/globals"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src", "test"]
}
